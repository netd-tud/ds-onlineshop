dn: olcDatabase={1}mdb,cn=config
changetype: modify
replace: olcAccess
olcAccess: {0}to attrs=userPassword
  by self write
  by dn.exact="cn=admin,dc=theonlineshop,dc=com" write
  by anonymous auth
  by * none
olcAccess: {1}to *
  by dn.exact="cn=admin,dc=theonlineshop,dc=com" write
  by dn.exact="cn=readonly,ou=service-accounts,dc=theonlineshop,dc=com" read
  by self read
  by * none
